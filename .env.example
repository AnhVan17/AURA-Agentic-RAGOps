# ============================================================
# AURA — Environment Variables
# ============================================================
# Copy file này thành .env và điền giá trị thực:
#   cp .env.example .env
# ============================================================

# ── Google AI (Bắt buộc) ─────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY_2=your_backup_google_api_key_here

# ── Groq (Optional — Fallback LLM) ──────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LangSmith Observability (Optional) ──────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=aura-rag

# ── App Config ───────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO

# ── Docker sẽ tự override các biến sau (không cần sửa) ──────
# QDRANT_URL=http://qdrant:6333
# REDIS_URL=redis://redis:6379
# API_BASE=http://api:8000
